{
  "name": "ai-slidev-corporate",
  "description": "Clean corporate theme for business presentations. Light background, professional colors.",
  "overrides": {
    "colors": {
      "primary": "#1E2761",
      "secondary": "#CADCFC",
      "accent": "#F96167",
      "background": "#FFFFFF"
    }
