  "style": "<style>\n:root {\n  --slidev-theme-primary: #1E2761;\n}\n\n.slidev-layout h1 {\n  color: #1E2761;\n  font-weight: 700;\n}\n\n.slidev-layout .accent {\n  color: #F96167;\n}\n</style>"
}
